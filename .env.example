# Core provider selector
AGENT_MODEL_PROVIDER=openai

# OpenAI-compatible settings
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5

# Optional: inline JSON model config override
# AGENT_MODEL_CONFIG_JSON={"provider":"openai","model":{"name":"gpt-5","apiKeyEnv":"OPENAI_API_KEY","baseUrl":"https://api.openai.com/v1","baseUrlEnv":"OPENAI_BASE_URL","modelEnv":"OPENAI_MODEL","capabilities":{"jsonOutput":true,"chatCompletions":true}}}

# Optional: load model config from file path instead
# AGENT_MODEL_CONFIG_PATH=./model-config.json
